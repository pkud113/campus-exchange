    "auth:v2": "node scripts/auth-v2-cutover.mjs"
  },
  "dependencies": {
    "@campus-exchange/contracts": "workspace:*",
    "@campus-exchange/domain": "workspace:*",
    "@opennextjs/cloudflare": "^1.6.5",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  }
