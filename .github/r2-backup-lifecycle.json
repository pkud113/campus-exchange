{
  "rules": [
    {
      "id": "expire-daily-database-backups",
      "enabled": true,
      "conditions": { "prefix": "database/daily/" },
      "deleteObjectsTransition": { "condition": { "type": "Age", "maxAge": 691200 } }
    },
    {
      "id": "expire-weekly-database-backups",
      "enabled": true,
      "conditions": { "prefix": "database/weekly/" },
      "deleteObjectsTransition": { "condition": { "type": "Age", "maxAge": 4838400 } }
    },
    {
      "id": "expire-monthly-database-backups",
      "enabled": true,
      "conditions": { "prefix": "database/monthly/" },
      "deleteObjectsTransition": { "condition": { "type": "Age", "maxAge": 34560000 } }
    },
    {
      "id": "abort-incomplete-backup-uploads",
      "enabled": true,
      "conditions": {},
      "abortMultipartUploadsTransition": { "condition": { "type": "Age", "maxAge": 604800 } }
    }
  ]
}
