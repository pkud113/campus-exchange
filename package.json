{
  "name": "campus-exchange",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "pnpm --filter @campus-exchange/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:reset": "supabase db reset",
    "db:start": "supabase start",
    "admin:invite": "pnpm --filter @campus-exchange/web admin:invite",
    "campus:admin": "pnpm --filter @campus-exchange/web campus:admin",
    "auth:v2": "pnpm --filter @campus-exchange/web auth:v2",
    "evidence:check": "node scripts/check-domain-evidence.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
